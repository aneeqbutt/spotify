<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#121212">

    <!-- App title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🤖 SpotifyBot"
        android:textSize="28sp"
        android:textColor="#1DB954"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spotify Automation Platform"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="48dp" />

    <!-- Accessibility Service status -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checking service status..."
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <!-- Open Accessibility Settings -->
    <Button
        android:id="@+id/btn_accessibility"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_open_accessibility"
        android:textColor="#FFFFFF"
        android:backgroundTint="#333333"
        android:layout_marginBottom="16dp" />

    <!-- Launch Spotify -->
    <Button
        android:id="@+id/btn_launch_spotify"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_launch_spotify"
        android:textColor="#000000"
        android:backgroundTint="#1DB954" />

</LinearLayout>
